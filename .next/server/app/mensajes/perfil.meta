{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/mensajes/layout,_N_T_/mensajes/perfil/layout,_N_T_/mensajes/perfil/page,_N_T_/mensajes/perfil"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/mensajes/perfil/__PAGE__",
    "/mensajes/perfil",
    "/mensajes",
    "/_index",
    "/_head"
  ]
}